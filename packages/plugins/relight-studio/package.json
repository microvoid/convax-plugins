  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "radix-ui": "1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "5.9.3"
  }
}
