{
  "schema": "convax.plugin/3",
  "id": "multi-angle",
  "name": "多角度",
  "description": "通过已安装的统一图片生成工具，一次生成一张多宫格图片，每个格子展示同一主体的一个一致视角。",
  "version": "0.1.0",
  "entry": "index.html",
  "capabilities": [
    "canvas.connectedImages.read",
    "canvas.node.write",
    "generation.execute"
  ],
  "contributes": {
    "canvas": {
      "renderer": {
        "create": true,
        "width": 1080,
        "height": 720
      },
      "toolbar": [
        {
          "id": "generate",
          "title": "生成多角度宫格图",
          "command": "multi-angle.generate"
        },
        {
          "id": "refresh",
          "title": "刷新参考图与模型",
          "command": "multi-angle.refresh"
        }
      ]
    }
  }
}
