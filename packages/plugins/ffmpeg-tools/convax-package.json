{
  "schema": "convax.package/1",
  "kind": "plugin",
  "id": "ffmpeg-tools",
  "name": "FFmpeg Tools",
  "description": "Runs reviewed local FFmpeg transforms against host-staged Canvas media without exposing native paths or a shell.",
  "version": "0.2.0",
  "license": "MIT",
  "compatibility": {
    "pluginSchema": "convax.plugin/3",
    "pluginHost": "convax.plugin-host/3"
  },
  "companions": [
    {
      "command": "convax-ffmpeg-mcp",
      "version": "0.2.0",
      "source": "tools/ffmpeg-mcp",
      "targets": [
        {
          "platform": "darwin",
          "arch": "arm64",
          "path": "dist/darwin-arm64/convax-ffmpeg-mcp"
        }
      ]
    }
  ],
  "yanked": false
}
